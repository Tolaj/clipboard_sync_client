{
  "$schema": "https://raw.githubusercontent.com/nicepage/nicepage-go/refs/heads/main/nicepage/data/tauri.conf.schema.json",
  "productName": "Clipboard Sync",
  "version": "1.0.1",
  "identifier": "com.clipboardsync.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:web"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Clipboard Sync",
        "width": 420,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  }
}
